# EggPool drop-in config for Claude Code (claude-cli)
#
# To use EggPool as the upstream for Claude Code, set these environment
# variables before starting Claude Code:
#
#   export ANTHROPIC_BASE_URL=http://localhost:11300
#   export ANTHROPIC_API_KEY=your-api-key-here
#
# Or add them to your shell profile (~/.zshrc, ~/.bashrc, etc.).
#
# If EggPool is running on a different host, replace localhost with the
# appropriate address (e.g., http://192.168.1.100:11300).

# Environment variables for the eggpool systemd unit.
#
# This file is loaded by systemd via EnvironmentFile. Do NOT commit
# real API keys to the repository. Install this template with
# restrictive permissions, then populate real values locally:
#
#   sudo cp deploy/env.example /etc/eggpool/env
#   sudo chown root:eggpool /etc/eggpool/env
#   sudo chmod 640 /etc/eggpool/env
#   sudo nano /etc/eggpool/env       # populate real values

# --- OpenCode Go API keys (one per account configured in config.toml) ---
OPENCODE_GO_KEY_1=replace-me
OPENCODE_GO_KEY_2=replace-me

# --- Local API key for the proxy itself ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
GO_AGGREGATOR_API_KEY=replace-me

# --- Optional overrides ---
# GOROUTER_CONFIG=/etc/eggpool/config.toml
# GOROUTER_LOG_LEVEL=INFO

# --- Operator scripts (used by scripts/smoke_test.py and scripts/check_database.py) ---
# Base URL for the local proxy (used by smoke_test.py)
# On the host itself: http://127.0.0.1:11300
# From another LAN machine: http://<host-ip>:11300
GOROUTER_BASE_URL=http://127.0.0.1:11300

# Database path (used by check_database.py)
GOROUTER_DB_PATH=/var/lib/eggpool/usage.sqlite3

# API keys for OpenCode Go accounts
# Set these to your actual API keys
OPENCODE_GO_KEY_1=your-api-key-here
OPENCODE_GO_KEY_2=your-api-key-here

# Local API key for authenticating to the proxy
GO_AGGREGATOR_API_KEY=your-local-api-key-here

# Base URL for the local proxy (used by smoke_test.py)
# On the Pi itself: http://127.0.0.1:8080
# From another LAN machine: http://<pi-ip>:8080
GOROUTER_BASE_URL=http://127.0.0.1:8080

# Database path (used by check_database.py)
GOROUTER_DB_PATH=/var/lib/eggpool/usage.sqlite3

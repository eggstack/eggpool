# Environment variables consumed by the eggpool systemd unit.
#
# This file is loaded by systemd via EnvironmentFile. Do NOT place
# actual API keys in this file as committed to the repository. Use
# the operator template here and install the real file separately with
# restrictive permissions.
#
# Example install steps:
#   sudo cp ops/eggpool.env.example /etc/eggpool/env
#   sudo chown root:eggpool /etc/eggpool/env
#   sudo chmod 640 /etc/eggpool/env
#   sudo nano /etc/eggpool/env       # populate real values

# --- OpenCode Go API keys (one per account configured in config.toml) ---
OPENCODE_GO_KEY_1=replace-me
OPENCODE_GO_KEY_2=replace-me

# --- Local API key for the proxy itself ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
GO_AGGREGATOR_API_KEY=replace-me

# --- Optional overrides ---
# GOROUTER_CONFIG=/etc/eggpool/config.toml
# GOROUTER_LOG_LEVEL=INFO
